# ── 访问控制 ─────────────────────────────────────────────────
# 网站访问密码（必填）
ACCESS_PASSWORD=your-password-here
# Session 加密密钥，随机字符串即可（必填）
SESSION_SECRET=random-secret-string

# ── 选择提供商 ──────────────────────────────────────────────
# anthropic  →  api.anthropic.com/v1/messages
# deepseek   →  api.deepseek.com/anthropic/v1/messages  (Anthropic-compatible)
PROVIDER=anthropic

# ── Anthropic（PROVIDER=anthropic 时填写）───────────────────
# 获取 key：https://platform.claude.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-

# ── DeepSeek（PROVIDER=deepseek 时填写）─────────────────────
# 获取 key：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-
# 指定模型（可选，默认用 index.jsx 里的 claude-sonnet-4-20250514 自动映射到 deepseek-v4-flash）
# DEEPSEEK_MODEL=deepseek-v4-pro
